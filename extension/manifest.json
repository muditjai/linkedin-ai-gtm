{
  "manifest_version": 3,
  "name": "LinkedIn AI GTM",
  "version": "1.0.0",
  "description": "AI-powered outreach capabilities for LinkedIn - automate messaging, analyze conversations, and orchestrate outreach campaigns.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["src/content/main.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    }
  ]
}