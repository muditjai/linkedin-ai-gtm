{
  "manifest_version": 3,
  "name": "LinkedIn AI GTM",
  "version": "1.0.0",
  "description": "AI-powered outreach for LinkedIn",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LinkedIn AI GTM"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/messaging/*"
      ],
      "js": [
        "content/main.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fullpage.html"
      ],
      "matches": [
        "*://*.linkedin.com/*"
      ]
    }
  ]
}
