{
  "manifest_version": 3,
  "name": "LinkedIn AI GTM",
  "version": "1.0.0",
  "description": "AI-powered outreach for LinkedIn",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LinkedIn AI GTM"
  }
}
