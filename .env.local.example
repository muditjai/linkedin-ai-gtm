# Local environment variables for the LinkedIn AI GTM extension.
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit secrets.

# Gemini API key (used by message analysis / reflection in Phase 3).
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the message-generation model. Defaults to a model from
# the DigitalOcean inference list. See README for supported values.
DO_GENERATION_MODEL=gpt-oss-20b

# Optional: DigitalOcean inference endpoint + token (Phase 3).
DO_INFERENCE_URL=
DO_INFERENCE_TOKEN=

# Optional: MongoDB connection string for the service backend (Phase 2).
MONGODB_URI=
