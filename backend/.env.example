# Copy to `.env.local` and fill in. Never commit `.env.local`.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (MongoDB) ---
# The backend (mongoose) connects via this URI. For local dev it points
# at a local MongoDB; in DigitalOcean production point it at the
# managed cluster's SRV URI. Real connection strings (with the
# password) live in `.env.local` / the k8s Secret, NOT in this repo.
MONGODB_URI=mongodb://localhost:27017/linkedin-ai
MONGODB_DB_NAME=linkedin-ai

# The test code (`backend/tests/db_client.py`) does NOT use the URI
# above. It connects via `mongodb+srv://MONGODB_HOST/?...` and
# authenticates with MONGODB-OIDC using the service-account creds
# below. See backend/tests/README.md for the Atlas-side setup that
# MONGODB-OIDC requires.
MONGODB_HOST=cluster0.psvmpm.mongodb.net
MONGODB_OIDC_AUDIENCE=https://www.mongodb.com/cloud/atlas

# --- Atlas service account (OAuth2 client_credentials) ---
# Used by backend/tests/db_client.py to authenticate to MongoDB via
# MONGODB-OIDC. Get the client_id + client_secret from
# Atlas -> Access Management -> Service Accounts. NEVER commit them.
MONGODB_ATLAS_CLIENT_ID=
MONGODB_ATLAS_CLIENT_SECRET=

# --- AI services ---
# Required. Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro

# Optional. If unset, message generation falls back to Gemini.
DO_INFERENCE_TOKEN=
DO_INFERENCE_BASE_URL=https://inference.digitalocean.com/v1
DO_INFERENCE_MODEL=gpt-oss-20b

# --- CORS ---
# Comma-separated list of origins allowed to call the API. Use
# chrome-extension://<id> for the extension. '*' is OK for local dev.
ALLOWED_ORIGINS=*

# --- Rate limiting (per IP) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
