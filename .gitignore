# Local environment files
.env
.env.local
.env.*
!.env.example
!.env.local.example

# Local skill installation artifacts
.agents/
skills-lock.json

# Extension build output and stale compiled artefacts
extension/dist/
extension/node_modules/
# Older build layout wrote a few stray .js files at the extension root.
# Modern builds write only into extension/dist/, so these should never come
# back. The negation below keeps config files (tailwind.config.js, …)
# tracked while still blocking bare-name artefacts like `background.js`.
extension/*.js
!extension/*.config.js

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
